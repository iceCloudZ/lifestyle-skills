{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lifestyle-skills.dev/schemas/lifestyle-skill.schema.json",
  "title": "Lifestyle Skill Registry Entry",
  "type": "object",
  "required": [
    "id",
    "name",
    "skill_type",
    "domain",
    "path",
    "description",
    "best_for",
    "avoid_if",
    "required_context",
    "style",
    "risk_level"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "skill_type": {
      "type": "string",
      "enum": ["entry", "lens"]
    },
    "domain": {
      "type": "string",
      "enum": ["life", "finance", "health", "movement", "family"]
    },
    "path": {
      "type": "string",
      "pattern": "^(skills/.+/SKILL.md|lenses/.+/.+\\.md)$"
    },
    "description": {
      "type": "string",
      "minLength": 20
    },
    "best_for": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "avoid_if": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_context": {
      "type": "array",
      "items": { "type": "string" }
    },
    "style": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  },
  "additionalProperties": false
}
